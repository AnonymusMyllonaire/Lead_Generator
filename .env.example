# No API key is required for the OpenStreetMap/Overpass version.

# Polar.sh subscription billing
JWT_SECRET=replace-with-a-long-random-secret
POLAR_WEBHOOK_SECRET=replace-with-the-secret-from-your-polar-webhook-endpoint
